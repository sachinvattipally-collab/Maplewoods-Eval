# Copy this file to .env and fill in your own values.
# Generate a secure JWT_SECRET with: openssl rand -hex 32

PORT=3001
JWT_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32_OUTPUT
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# Passwords used only when running: npm run seed
# Must satisfy: 8+ chars, at least one uppercase, lowercase, and digit
REVIEWER_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
